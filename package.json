{
  "name": "invisible-sloth-website",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "npm@10.9.4",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "check:rich-text": "node scripts/check-rich-text-contract.mjs",
    "tokens:reconcile": "node scripts/reconcile-design-tokens.mjs",
    "tokens:check": "node scripts/reconcile-design-tokens.mjs --check",
    "test:tokens": "node --test scripts/reconcile-design-tokens.test.mjs",
    "icons:optimize": "svgo -f src/icons/raw -o src/icons/optimized",
    "logos:optimize": "svgo --config .svgorc.logos.cjs -f src/logos/raw -o src/logos/optimized",
    "logos:copy": "mkdir -p public/logos && cp src/logos/optimized/invisible-sloth-logo-technical-light.svg public/logos/logo-technical-light.svg && cp src/logos/optimized/invisible-sloth-logo-technical-dark.svg public/logos/logo-technical-dark.svg && cp src/logos/optimized/invisible-sloth-logo-light.svg public/logos/logo-standard-light.svg && cp src/logos/optimized/invisible-sloth-logo-dark.svg public/logos/logo-standard-dark.svg",
    "logos:build": "npm run logos:optimize && npm run logos:copy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/svelte": "^9.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.8",
    "svelte": "^5.56.4",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/svelte-vite": "^10.5.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "storybook": "^10.5.0",
    "svgo": "^4.0.2",
    "tailwindcss": "^4.3.2"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": "2.8.3"
    }
  }
}
