---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
}

const {
  title = "Invisible Sloth",
  description = "Invisible Sloth creates imaginative indie games and apps.",
  canonicalUrl,
} = Astro.props as Props;

// Build canonical URL: use prop if provided, otherwise construct from Astro.url
const canonical = (canonicalUrl || new URL(Astro.url.pathname, Astro.site)).toString();
const socialCardUrl = new URL("/social-card.png", Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="noai, noimageai" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="color-scheme" content="light dark" />
    <meta
      name="theme-color"
      content="#151818"
      media="(prefers-color-scheme: dark)"
      data-system-theme-color
    />
    <meta
      name="theme-color"
      content="#f8faf6"
      media="(prefers-color-scheme: light)"
      data-system-theme-color
    />

    <script is:inline>
      document.documentElement.dataset.js = "true";
      document.documentElement.dataset.imageEnhancer = "pending";
    </script>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const manualThemeColorSelector = 'meta[name="theme-color"][data-manual-theme-color]';
        const systemThemeColorSelector = 'meta[name="theme-color"][data-system-theme-color]';
        let syncFrame = 0;

        const setSystemThemeColorRouting = (enabled) => {
          document.querySelectorAll(systemThemeColorSelector).forEach((meta) => {
            if (!(meta instanceof HTMLMetaElement)) {
              return;
            }

            if (!meta.dataset.systemThemeColorMedia) {
              meta.dataset.systemThemeColorMedia = meta.getAttribute('media') ?? '';
            }

            if (enabled) {
              const media = meta.dataset.systemThemeColorMedia;

              if (media) {
                meta.setAttribute('media', media);
              } else {
                meta.removeAttribute('media');
              }

              return;
            }

            meta.setAttribute('media', 'not all');
          });
        };

        const readConcreteBackgroundColor = () => {
          const probe = document.createElement('span');
          probe.style.cssText = [
            'position: fixed',
            'inline-size: 0',
            'block-size: 0',
            'overflow: hidden',
            'pointer-events: none',
            'background-color: var(--color-background)'
          ].join(';');

          (document.body || root).appendChild(probe);
          const color = getComputedStyle(probe).backgroundColor.trim();
          probe.remove();

          return color;
        };

        const syncManualThemeColor = () => {
          syncFrame = 0;

          const theme = root.dataset.theme;
          const hasManualTheme = theme === 'light' || theme === 'dark';
          let manualThemeColor = document.querySelector(manualThemeColorSelector);

          if (!hasManualTheme) {
            manualThemeColor?.remove();
            setSystemThemeColorRouting(true);
            return;
          }

          const color = readConcreteBackgroundColor();

          if (!color || color.includes('var(')) {
            manualThemeColor?.remove();
            setSystemThemeColorRouting(true);
            return;
          }

          if (!manualThemeColor) {
            manualThemeColor = document.createElement('meta');
            manualThemeColor.setAttribute('name', 'theme-color');
            manualThemeColor.dataset.manualThemeColor = 'true';
            manualThemeColor.setAttribute('content', color);
            document.head.appendChild(manualThemeColor);
          } else {
            manualThemeColor.setAttribute('content', color);
          }

          setSystemThemeColorRouting(false);
        };

        const requestThemeColorSync = () => {
          if (syncFrame) {
            return;
          }

          syncFrame = requestAnimationFrame(syncManualThemeColor);
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', requestThemeColorSync, { once: true });
        } else {
          requestThemeColorSync();
        }

        new MutationObserver(requestThemeColorSync).observe(root, {
          attributes: true,
          attributeFilter: ['data-theme']
        });
      })();
    </script>

    <link rel="canonical" href={canonical} />
    <link rel="license" href="/LICENSE" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialCardUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialCardUrl} />

    <!-- Google Fonts - Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Load Sigmar (display font) and Work Sans (body font) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Sigmar&family=Work+Sans:ital,wght@0,400;0,500;0,600;1,400;1,600&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (() => {
        const polyfillRemove = (Ctor) => {
          if (typeof Ctor !== 'undefined' && Ctor.prototype && !Ctor.prototype.remove) {
            Ctor.prototype.remove = function () {
              if (this.parentNode) {
                this.parentNode.removeChild(this);
              }
            };
          }
        };
        polyfillRemove(DocumentFragment);
        polyfillRemove(DocumentType);
      })();
    </script>

    <title>{title}</title>
  </head>
  <body class="page">
    <slot />

    <script>
      const isDev = import.meta.env.DEV;

      const markImageEnhancerUnavailable = () => {
        document.documentElement.dataset.imageEnhancer = "unavailable";
      };

      const initImageLoading = async () => {
        try {
          const { initImageLoadingEnhancer } = await import("../scripts/imageLoadingEnhancer");
          initImageLoadingEnhancer(document);
        } catch (error) {
          markImageEnhancerUnavailable();

          if (isDev) {
            console.warn("Image loading enhancer initialization failed.", error);
          }
        }
      };

      const initLogoTilt = async () => {
        try {
          const { initLogoHoverTilt } = await import("../scripts/logoHoverTilt");
          initLogoHoverTilt(document);
        } catch (error) {
          if (isDev) {
            console.warn("Logo hover tilt initialization failed.", error);
          }
        }
      };

      void initImageLoading();
      void initLogoTilt();
    </script>
  </body>
</html>
